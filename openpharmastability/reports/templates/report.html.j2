<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="generator" content="OpenPharmaStability v{{ tool_version }}">
  <title>{{ title }} | {{ attribute }} at {{ condition }}</title>
  <style>
    :root {
      --ink: #26211e;
      --muted: #6d625b;
      --faint: #8a7e76;
      --accent: #a6533b;
      --accent-soft: #f4ddd3;
      --sage: #5e745d;
      --amber: #9b6b2f;
      --fail: #9b3029;
      --bg: #f7f1e8;
      --paper: #fffaf2;
      --surface: #fdf7ee;
      --line: #ded0c1;
      --line-strong: #bfae9c;
    }
    * { box-sizing: border-box; }
    body {
      font-family: "IBM Plex Sans", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: var(--ink);
      background: var(--bg);
      margin: 0;
      line-height: 1.5;
    }
    .container {
      max-width: 1080px;
      margin: 0 auto;
      padding: 34px 30px 64px;
    }
    header {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fffaf2 0%, #fbf2e7 100%);
      padding: 28px;
      margin-bottom: 18px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      align-items: end;
    }
    header h1 {
      margin: 0 0 10px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 4vw, 3.8rem);
      line-height: 0.95;
      letter-spacing: 0;
      color: var(--ink);
      font-weight: 500;
    }
    .report-kicker {
      color: var(--accent);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .decision-block {
      border-left: 2px solid var(--accent);
      padding-left: 18px;
      min-width: 210px;
    }
    .decision-label {
      color: var(--muted);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 700;
    }
    .decision-value {
      display: block;
      margin-top: 4px;
      color: var(--accent);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 2.3rem;
      line-height: 1;
      font-weight: 600;
    }
    .decision-note {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.82rem;
    }
    .subtitle {
      color: var(--muted);
      font-size: 0.95rem;
      max-width: 760px;
    }
    .meta-strip {
      border: 1px solid var(--line);
      background: var(--paper);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      margin-bottom: 20px;
    }
    .meta-item {
      padding: 12px 14px;
      border-right: 1px solid var(--line);
    }
    .meta-item:last-child { border-right: 0; }
    .meta-label {
      color: var(--faint);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 700;
    }
    .meta-value {
      margin-top: 4px;
      font-size: 0.94rem;
      font-weight: 650;
    }
    h2 {
      margin: 30px 0 10px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.55rem;
      line-height: 1.15;
      color: var(--ink);
      font-weight: 500;
    }
    h3 {
      margin: 18px 0 8px;
      font-size: 0.95rem;
      color: var(--ink);
    }
    .section-lede {
      color: var(--muted);
      margin: 0 0 12px;
      max-width: 780px;
      font-size: 0.94rem;
    }
    .card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 4px;
      padding: 18px;
      margin: 10px 0 18px;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: 1px solid var(--line);
      background: var(--paper);
    }
    .summary-cell {
      padding: 16px;
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      min-height: 94px;
    }
    .summary-cell:nth-child(4n) { border-right: 0; }
    .summary-cell strong {
      display: block;
      color: var(--faint);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .summary-cell span {
      font-size: 1rem;
      font-weight: 650;
    }
    table.summary {
      border-collapse: collapse;
      width: 100%;
    }
    table.summary th, table.summary td {
      text-align: left;
      padding: 9px 8px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
      font-size: 0.93rem;
    }
    table.summary tr:last-child th,
    table.summary tr:last-child td {
      border-bottom: 0;
    }
    table.summary th {
      width: 34%;
      color: var(--muted);
      font-weight: 650;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 22px;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      margin-left: 4px;
      vertical-align: middle;
    }
    .badge.ok    { background: #e8efe5; color: var(--sage); }
    .badge.fail  { background: #f6d9d4; color: var(--fail); }
    .badge.warn  { background: #f6ead7; color: var(--amber); }
    .badge.info  { background: var(--accent-soft); color: var(--accent); }
    .decision-shelf-life { color: var(--accent); font-weight: 800; }
    .plot {
      text-align: center;
      margin: 4px 0;
    }
    .plot img {
      max-width: 100%;
      height: auto;
      border: 1px solid var(--line-strong);
      border-radius: 4px;
      background: #fff;
    }
    .plot-caption {
      color: var(--muted);
      font-size: 0.85rem;
      margin-top: 10px;
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
    }
    ul.notes {
      margin: 8px 0 0 18px;
      padding: 0;
    }
    ul.notes li { margin: 5px 0; }
    ul.warnings {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 8px;
    }
    ul.warnings li {
      border-left: 3px solid var(--amber);
      background: #fbf0dd;
      padding: 10px 12px;
      color: #513b20;
    }
    .disclaimer {
      background: #efe4d7;
      border: 1px solid var(--line-strong);
      border-left: 4px solid var(--accent);
      padding: 14px 16px;
      font-size: 0.9rem;
      color: #3f3832;
      margin-top: 32px;
    }
    .disclaimer strong { color: var(--ink); }
    footer {
      margin-top: 24px;
      color: var(--muted);
      font-size: 0.82rem;
      border-top: 1px solid var(--line);
      padding-top: 12px;
    }
    code, .mono {
      font-family: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
      font-size: 0.9em;
    }
    .kv-table {
      display: grid;
      grid-template-columns: minmax(120px, 0.7fr) minmax(0, 1fr);
      border: 1px solid var(--line);
      margin-top: 6px;
    }
    .kv-table div {
      padding: 8px 10px;
      border-bottom: 1px solid var(--line);
      min-width: 0;
      overflow-wrap: anywhere;
    }
    .kv-table div:nth-last-child(-n + 2) { border-bottom: 0; }
    .kv-table .key {
      color: var(--muted);
      background: var(--surface);
      border-right: 1px solid var(--line);
      font-weight: 650;
    }
    .two-col {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 14px;
    }
    .muted { color: var(--muted); }
    @media (max-width: 760px) {
      .container { padding: 18px 14px 42px; }
      header { grid-template-columns: 1fr; padding: 22px; }
      .decision-block { border-left: 0; border-top: 2px solid var(--accent); padding: 14px 0 0; }
      .meta-strip, .summary-grid, .two-col { grid-template-columns: 1fr; }
      .meta-item { border-right: 0; border-bottom: 1px solid var(--line); }
      .summary-cell { border-right: 0; }
      table.summary th, table.summary td { display: block; width: 100%; }
      table.summary th { border-bottom: 0; padding-bottom: 2px; }
      table.summary td { padding-top: 2px; }
      .kv-table { grid-template-columns: 1fr; }
      .kv-table .key { border-right: 0; border-bottom: 0; }
    }
  </style>
</head>
<body>
  <div class="container">

    <header>
      <div>
        <div class="report-kicker">OpenPharmaStability report</div>
        <h1>Stability analysis</h1>
        <div class="subtitle">
          ICH Q1E inspired decision support for <strong>{{ attribute }}</strong>
          at <strong>{{ condition }}</strong>. The Python engine owns the model,
          confidence bound, crossing estimate, reproducibility metadata, and artifact record.
        </div>
      </div>
      <div class="decision-block">
        <span class="decision-label">Supported {{ deliverable_term }}</span>
        <span class="decision-value">{{ supported_shelf_life_text }}</span>
        <div class="decision-note">Statistical crossing {{ statistical_crossing_months }} months. Rounded down to a whole month.</div>
      </div>
    </header>

    <div class="meta-strip">
      <div class="meta-item">
        <div class="meta-label">Attribute</div>
        <div class="meta-value">{{ attribute }}</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Condition</div>
        <div class="meta-value">{{ condition }}</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Direction</div>
        <div class="meta-value">{{ direction }}</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Term</div>
        <div class="meta-value">{{ deliverable_term }}{% if product_type %} for {{ product_type }}{% endif %}</div>
      </div>
    </div>

    <h2>Decision Summary</h2>
    <p class="section-lede">
      The headline decision is the earliest supported period implied by the selected model
      and one sided confidence bound. Internal ids are retained in badges for audit traceability.
    </p>
    <div class="summary-grid">
      <div class="summary-cell">
        <strong>Supported {{ deliverable_term }}</strong>
        <span class="decision-shelf-life">{{ supported_shelf_life_text }}</span>
      </div>
      <div class="summary-cell">
        <strong>Statistical crossing</strong>
        <span>{{ statistical_crossing_months }} months</span>
      </div>
      <div class="summary-cell">
        <strong>Observed data</strong>
        <span>{{ observed_data_months }} months</span>
      </div>
      <div class="summary-cell">
        <strong>Governing batch</strong>
        <span>{{ governing_batch }}</span>
      </div>
      <div class="summary-cell">
        <strong>Model selected</strong>
        <span>{{ model_kind_human }}</span>
      </div>
      <div class="summary-cell">
        <strong>Poolability alpha</strong>
        <span>{{ poolability_alpha }}</span>
      </div>
      <div class="summary-cell">
        <strong>Confidence bound</strong>
        <span>{{ confidence_bound_label }}</span>
      </div>
      <div class="summary-cell">
        <strong>Extrapolation</strong>
        <span>{{ extrapolation_text }}</span>
      </div>
    </div>

    <h2>Dataset</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Attribute</th>
          <td>{{ attribute }}</td>
        </tr>
        <tr>
          <th>Unit</th>
          <td>
            {{ unit }}
          </td>
        </tr>
        <tr>
          <th>Condition</th>
          <td>{{ condition }}</td>
        </tr>
        <tr>
          <th>Direction</th>
          <td>{{ direction }}</td>
        </tr>
        <tr>
          <th>Number of batches</th>
          <td>
            {% if n_batches is not none %}{{ n_batches }}
            {% else %}Not recorded in metadata{% endif %}
          </td>
        </tr>
        <tr>
          <th>Time points (months)</th>
          <td>
            {% if time_points %}
              <code class="mono">{{ time_points|join(", ") }}</code>
            {% else %}
              Not recorded in metadata
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Row count used in fit</th>
          <td>
            {% if row_count is not none %}{{ row_count }}
            {% else %}Not recorded in metadata{% endif %}
          </td>
        </tr>
        <tr>
          <th>Required-column validation</th>
          <td>
            <span class="badge {{ validation_status_css }}">{{ validation_status }}</span>
          </td>
        </tr>
      </table>
    </div>

    <h2>Model</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Model kind</th>
          <td>{{ model_kind_human }} <span class="badge info">{{ model_kind_value }}</span></td>
        </tr>
        <tr>
          <th>Model formula</th>
          <td><code class="mono">{{ model_formula }}</code></td>
        </tr>
        <tr>
          <th>Estimated parameters</th>
          <td>
            {% if fit_param_rows %}
              <div class="kv-table">
                {% for row in fit_param_rows %}
                  <div class="key"><code class="mono">{{ row.key }}</code></div>
                  <div><code class="mono">{{ row.value }}</code></div>
                {% endfor %}
              </div>
            {% else %}
              <em>not recorded</em>
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Residual df</th>
          <td>{{ fit_df_resid }}</td>
        </tr>
        <tr>
          <th>Residual standard error (s)</th>
          <td>{{ "%.6g"|format(fit_s_resid) }}</td>
        </tr>
        <tr>
          <th>Batches in fit</th>
          <td>
            {% if fit_batches %}
              <code class="mono">{{ fit_batches_display }}</code>
            {% else %}
              not recorded
            {% endif %}
          </td>
        </tr>
      </table>
    </div>

    <h2>Poolability</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Decision</th>
          <td>
            {{ poolability_human }}
            <span class="badge info">{{ poolability_decision }}</span>
          </td>
        </tr>
        <tr>
          <th>Alpha (significance level)</th>
          <td>{{ poolability_alpha }}
              (ICH Q1E reference alpha = {{ poolability_alpha_ref }})</td>
        </tr>
        <tr>
          <th>Guidance profile</th>
          <td>{{ guidance_profile }}</td>
        </tr>
        <tr>
          <th>Step 1 p-value for slopes</th>
          <td>
            <code class="mono">{{ p_value_slopes }}</code>
            {% if p_value_slopes != "not run" %}
              {% if p_value_slopes|float < poolability_alpha %}
                &lt; alpha, slopes differ, no pooling
              {% else %}
                &ge; alpha, proceed to intercept test
              {% endif %}
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Step 2 p-value for intercepts</th>
          <td>
            <code class="mono">{{ p_value_intercepts }}</code>
            {% if p_value_intercepts != "not run" %}
              {% if p_value_intercepts|float < poolability_alpha %}
                &lt; alpha, intercepts differ, common slope
              {% else %}
                &ge; alpha, nothing rejected, full pooling
              {% endif %}
            {% else %}
              (not performed; slopes differ)
            {% endif %}
          </td>
        </tr>
        {% if poolability_notes %}
        <tr>
          <th>Poolability notes</th>
          <td>
            <ul class="notes">
              {% for n in poolability_notes %}<li>{{ n }}</li>{% endfor %}
            </ul>
          </td>
        </tr>
        {% endif %}
      </table>
    </div>

    <h2>Shelf Life Estimate</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Supported {{ deliverable_term }}</th>
          <td class="decision-shelf-life">{{ supported_shelf_life_text }}</td>
        </tr>
        <tr>
          <th>Statistical crossing (months)</th>
          <td>{{ statistical_crossing_months }}</td>
        </tr>
        <tr>
          <th>Observed long-term data (months)</th>
          <td>{{ observed_data_months }}</td>
        </tr>
        <tr>
          <th>Confidence bound used</th>
          <td>{{ confidence_bound_label }}
              <span class="badge info">{{ confidence_bound_id }}</span>
              (level = {{ confidence_level }})</td>
        </tr>
        <tr>
          <th>Crossing status</th>
          <td>{{ crossing_status_human }}
              <span class="badge info">{{ crossing_status_value }}</span></td>
        </tr>
        <tr>
          <th>Governing batch</th>
          <td>{{ governing_batch }}</td>
        </tr>
        <tr>
          <th>Extrapolation</th>
          <td>{{ extrapolation_text }}</td>
        </tr>
      </table>
      <p style="font-size: 0.85rem; color: var(--muted); margin-top: 8px;">
        The supported {{ deliverable_term }} is rounded <em>down</em> to the
        nearest whole month, per ICH Q1E.
      </p>
    </div>

    <h2>Confidence Bound Plot</h2>
    <div class="card">
      {% if plot_src %}
        <div class="plot">
          <img src="{{ plot_src }}" alt="Confidence-bound plot for {{ attribute }} at {{ condition }}">
          <div class="plot-caption">
            Observed data by batch, fitted regression, the
            {{ confidence_bound_label|lower }}, and the relevant
            specification limit. Crossing point and extrapolation region
            are marked. Plot file: <code class="mono">{{ plot_src }}</code>.
          </div>
        </div>
      {% else %}
        <p><em>No plot was supplied. Re-run the analysis with a confidence-bound
        PNG to embed it here.</em></p>
      {% endif %}
    </div>

    <h2>Diagnostics and Assumptions</h2>
    <div class="card">
      <div class="two-col">
        <div>
          <p>
            Linearity:
            {% if linearity_ok %}
              <span class="badge ok">ok</span>
            {% else %}
              <span class="badge warn">flagged</span>
            {% endif %}
          </p>
          <p>
            Homoscedasticity:
            {% if homoscedastic_ok %}
              <span class="badge ok">ok</span>
            {% else %}
              <span class="badge warn">flagged</span>
            {% endif %}
          </p>
          <p>
            Normality of residuals:
            {% if normal_resid_ok %}
              <span class="badge ok">ok</span>
            {% else %}
              <span class="badge warn">flagged</span>
            {% endif %}
          </p>
          <p>
            Influential points (Cook's d):
            <span class="badge {% if n_influential_points == 0 %}ok{% else %}warn{% endif %}">
              {{ n_influential_points }}
            </span>
          </p>
        </div>
        <div>
          {% if diagnostics_notes %}
            <strong>Diagnostic notes</strong>
            <ul class="notes">
              {% for n in diagnostics_notes %}<li>{{ n }}</li>{% endfor %}
            </ul>
          {% else %}
            <p><em>No diagnostic notes.</em></p>
          {% endif %}
        </div>
      </div>
    </div>

    <h2>Warnings and Limitations</h2>
    <div class="card">
      {% if warnings %}
        <ul class="notes warnings">
          {% for w in warnings %}<li>{{ w }}</li>{% endfor %}
        </ul>
      {% else %}
        <p><em>No warnings.</em></p>
      {% endif %}
    </div>

    {% if extrapolation_rationale or significant_change_details %}
    <h2>Significant-change assessment (ICH Q1A)</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Accelerated condition</th>
          <td>{{ significant_change_accelerated or "not recorded" }}</td>
        </tr>
        <tr>
          <th>Intermediate condition</th>
          <td>{{ significant_change_intermediate or "not recorded" }}</td>
        </tr>
        <tr>
          <th>Extrapolation allowed</th>
          <td>
            {% if extrapolation_allowed %}
              <span class="badge ok">yes</span>
            {% else %}
              <span class="badge fail">NO</span>
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Rationale</th>
          <td><code class="mono">{{ extrapolation_rationale or "not recorded" }}</code></td>
        </tr>
      </table>
      {% if extrapolation_criterion_notes %}
      <h3>Criteria fired</h3>
      <table class="summary">
        <tr>
          <th>Criterion</th>
          <th>First change (months)</th>
          <th>Evidence</th>
        </tr>
        {% for row in extrapolation_criterion_notes %}
        <tr>
          <td>{{ row.criterion }}</td>
          <td>
            {% if row.first_t is not none %}
              {{ "%.2f"|format(row.first_t) }}
            {% else %}
              not recorded
            {% endif %}
          </td>
          <td>{{ row.evidence }}</td>
        </tr>
        {% endfor %}
      </table>
      {% endif %}
    </div>
    {% endif %}

    <h2>Model effects</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Model</th>
          <td><code class="mono">{{ model_effects }}</code>
            {% if model_effects_is_random %}
              <em>(random effects or mixed model; not the ICH Q1E default; exploratory only)</em>
            {% else %}
              (Q1E default fixed effect batch)
            {% endif %}
          </td>
        </tr>
        {% if model_effects == "random" %}
        <tr>
          <th>Model convergence</th>
          <td>
            {% if model_convergence_converged %}converged{% else %}<strong>NOT converged</strong>{% endif %}
            {% if model_convergence_boundary %} <em>(boundary)</em>{% endif %}
            {% if model_convergence_message %}<br><code class="mono">{{ model_convergence_message }}</code>{% endif %}
          </td>
        </tr>
        {% endif %}
      </table>
    </div>

    {% if arrhenius_present %}
    <h2>Arrhenius analysis (exploratory)</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>n_temps</th>
          <td>{{ arrhenius_result.n_temps }}</td>
        </tr>
        <tr>
          <th>Ea</th>
          <td>{{ "%.2f"|format(arrhenius_result.Ea_J_per_mol) }} J/mol</td>
        </tr>
        <tr>
          <th>ln(A)</th>
          <td>{{ "%.4f"|format(arrhenius_result.ln_A) }}</td>
        </tr>
        <tr>
          <th>A</th>
          <td>{{ "%.4g"|format(arrhenius_result.A) }}</td>
        </tr>
        <tr>
          <th>R²</th>
          <td>{{ "%.4f"|format(arrhenius_result.r_squared) }}</td>
        </tr>
        <tr>
          <th>storage temp</th>
          <td>{{ arrhenius_result.storage_temp_C }} °C</td>
        </tr>
        <tr>
          <th>predicted k at storage</th>
          <td>{{ "%.4g"|format(arrhenius_result.predicted_k_at_storage) }} 1/month</td>
        </tr>
      </table>
      {% if arrhenius_result.notes %}
      <p class="muted">Notes:
        {% for n in arrhenius_result.notes %}<br>&middot; {{ n }}{% endfor %}
      </p>
      {% endif %}
    </div>
    {% endif %}

    {% if mkt_present %}
    <h2>Mean kinetic temperature (USP &lt;1160&gt;)</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>MKT</th>
          <td>{{ "%.2f"|format(mkt_celsius) }} °C</td>
        </tr>
        <tr>
          <th>model_effects</th>
          <td><code class="mono">{{ model_effects }}</code></td>
        </tr>
      </table>
    </div>
    {% endif %}

    {% if reduced_design_present %}
    <h2>Reduced design (ICH Q1D)</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Bracketed</th>
          <td>{{ "yes" if reduced_design_report.is_bracketed else "no" }}</td>
        </tr>
        <tr>
          <th>Matrixed</th>
          <td>{{ "yes" if reduced_design_report.is_matrixed else "no" }}</td>
        </tr>
        <tr>
          <th>Missing cells</th>
          <td>{{ reduced_design_report.missing_cells|length }}</td>
        </tr>
        {% if reduced_design_report.note %}
        <tr>
          <th>Note</th>
          <td>{{ reduced_design_report.note }}</td>
        </tr>
        {% endif %}
      </table>
    </div>
    {% endif %}

    {% if sensitivity_present %}
    <h2>Sensitivity analysis over Cook's distance outliers</h2>
    <div class="card">
      <p><em>{{ sensitivity_report.summary }}</em> ({{ "row-level" if sensitivity_mode == "row" else "batch-level" }})</p>
      <table class="summary">
        <tr>
          <th>Influential row</th>
          <th>Baseline shelf (mo)</th>
          <th>Leave-one-out shelf (mo)</th>
          <th>&Delta; (mo)</th>
          <th>Note</th>
        </tr>
        {% for r in sensitivity_report.rows %}
        <tr>
          <td>{{ r.influential_row_index }}</td>
          <td>{{ r.baseline_supported_shelf_life }}</td>
          <td>{{ r.leave_one_out_supported_shelf_life if r.leave_one_out_supported_shelf_life is not none else "not recorded" }}</td>
          <td>{{ r.diff_supported_shelf_life_months }}</td>
          <td>{{ r.note or "" }}</td>
        </tr>
        {% endfor %}
      </table>
      {% if sensitivity_report.notes %}
      <p class="muted">Notes:
        {% for n in sensitivity_report.notes %}<br>&middot; {{ n }}{% endfor %}
      </p>
      {% endif %}
    </div>
    {% endif %}

    {% if arrhenius_shelf_life_present %}
    <h2>Arrhenius-driven shelf-life prediction (exploratory)</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Storage temperature</th>
          <td>{{ arrhenius_shelf_life.storage_temp_C }} &deg;C</td>
        </tr>
        <tr>
          <th>Temperatures used</th>
          <td>{{ arrhenius_shelf_life.n_temps }} ({{ arrhenius_shelf_life.temperatures_used|join(', ') }})</td>
        </tr>
        <tr>
          <th>Predicted rate at storage</th>
          <td>{{ "%.4g"|format(arrhenius_shelf_life.predicted_k_at_storage) }} 1/month</td>
        </tr>
        <tr>
          <th>Predicted statistical crossing</th>
          <td>
            {% if arrhenius_shelf_life.predicted_statistical_crossing_months is not none %}
              {{ "%.2f"|format(arrhenius_shelf_life.predicted_statistical_crossing_months) }} mo
            {% else %}
              not recorded
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Predicted supported shelf life</th>
          <td>
            {% if arrhenius_shelf_life.predicted_shelf_life_months is not none %}
              {{ arrhenius_shelf_life.predicted_shelf_life_months }} mo
            {% else %}
              not recorded
            {% endif %}
          </td>
        </tr>
      </table>
      {% if arrhenius_shelf_life.notes %}
      <p class="muted">Notes:
        {% for n in arrhenius_shelf_life.notes %}<br>&middot; {{ n }}{% endfor %}
      </p>
      {% endif %}
      <p style="font-size: 0.85rem; color: var(--muted); margin-top: 8px;">
        Exploratory model-based prediction; the official {{ deliverable_term }} decision above is unchanged.
      </p>
    </div>
    {% endif %}

    {% if arrhenius_per_batch_present %}
    <h2>Per-batch Arrhenius rate diagnostic (v0.9.0)</h2>
    <div class="card">
      <p>Per-batch first-order rate estimates from the per-(batch, temperature) log-linear fit.
         Outlier flagging uses a robust z-score (MAD-scaled) over the per-temperature batches;
         batches with |z| &gt; 2.5 in at least one temperature are listed below.</p>
      <table class="summary">
        <tr>
          <th>Batch</th>
          <th>Per-temperature rates (1/month)</th>
        </tr>
        {% for batch, rates in arrhenius_per_batch.items() %}
        <tr>
          <td>
            <code class="mono">{{ batch }}</code>
            {% if batch in arrhenius_outlier_batches %}
              <span class="badge warn">outlier</span>
            {% endif %}
          </td>
          <td>
            <code class="mono">{% for t, k in rates.items() %}{{ t }}&deg;C: {{ "%.4g"|format(k) }}{% if not loop.last %} &middot; {% endif %}{% endfor %}</code>
          </td>
        </tr>
        {% endfor %}
      </table>
      {% if arrhenius_outlier_batches %}
      <p class="muted">
        Outlier batches (robust z-score &gt; 2.5 in at least one temperature):
        <strong>{{ arrhenius_outlier_batches|join(", ") }}</strong>
      </p>
      {% else %}
      <p class="muted">No outlier batches detected (robust z-score &le; 2.5 for all batches).</p>
      {% endif %}
      <p style="font-size: 0.85rem; color: var(--muted); margin-top: 8px;">
        Exploratory per-batch diagnostic; the official {{ deliverable_term }} decision above is unchanged.
      </p>
    </div>
    {% endif %}

    <h2>Reproducibility</h2>
    <div class="card">
      <table class="summary">
        <tr>
          <th>Tool version</th>
          <td><code class="mono">{{ tool_version }}</code></td>
        </tr>
        <tr>
          <th>Analysis timestamp (ISO-8601)</th>
          <td><code class="mono">{{ timestamp }}</code></td>
        </tr>
        <tr>
          <th>Input file SHA-256</th>
          <td>
            {% if file_sha256 %}
              <code class="mono">{{ file_sha256 }}</code>
            {% else %}
              <em>not recorded</em>
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Random seed (if any)</th>
          <td>
            {% if random_seed is not none %}
              <code class="mono">{{ random_seed }}</code>
            {% else %}
              <em>none / deterministic core</em>
            {% endif %}
          </td>
        </tr>
        <tr>
          <th>Library versions</th>
          <td>
            {% if library_version_rows %}
              <div class="kv-table">
                {% for row in library_version_rows %}
                  <div class="key"><code class="mono">{{ row.key }}</code></div>
                  <div><code class="mono">{{ row.value }}</code></div>
                {% endfor %}
              </div>
            {% else %}
              <em>not recorded</em>
            {% endif %}
          </td>
        </tr>
      </table>
    </div>

    <div class="disclaimer">
      <strong>Disclaimer.</strong> {{ disclaimer }}
    </div>

    <footer>
      Generated by OpenPharmaStability v{{ tool_version }} on
      <code class="mono">{{ timestamp }}</code>.
      This report is intended for educational, exploratory, and reproducible
      decision-support use; it is not a substitute for qualified regulatory,
      statistical, or quality review.
    </footer>

  </div>
</body>
</html>
